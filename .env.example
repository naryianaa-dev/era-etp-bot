# Telegram Bot API token (получить у @BotFather)
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Список админов — Telegram user id через запятую (узнать можно у @userinfobot).
# Сообщения /offer и подобные команды доступны только этим пользователям.
ADMIN_IDS=123456789

# Путь к файлу БД (SQLite). В Docker маппится на volume.
DB_PATH=./data/bot.sqlite3

# Минимальная предоплата в рублях (15% от суммы, но не меньше).
PREPAY_MIN_RUB=100000
PREPAY_PCT=15

# Часовой пояс для отображения дат пользователю
TZ=Europe/Moscow

# Режим логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
